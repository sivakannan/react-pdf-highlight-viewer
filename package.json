{
  "name": "react-pdf-highlight-viewer",
  "version": "1.1.4",
  "description": "A lightweight React library for rendering PDFs with text highlighting support",
  "keywords": [
    "react",
    "pdf",
    "highlight",
    "viewer",
    "react-pdf",
    "pdf-highlighter",
    "text-highlight",
    "document-viewer"
  ],
  "author": "Sivakkannan R",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/sivakannan/react-pdf-highlight-viewer"
  },
  "bugs": {
    "url": "https://github.com/sivakannan/react-pdf-highlight-viewer/issues"
  },
  "homepage": "https://github.com/sivakannan/react-pdf-highlight-viewer#readme",
  "private": false,
  "type": "module",
  "main": "./dist/react-pdf-highlighter.umd.js",
  "module": "./dist/react-pdf-highlighter.es.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:ui": "vitest --ui",
    "prepublishOnly": "npm run build"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0",
    "react-pdf": "^10.3.0"
  },
  "dependencies": {
    "prop-types": "^15.8.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.5",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "@vitest/coverage-v8": "^4.0.18",
    "@vitest/ui": "^4.0.18",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "happy-dom": "^20.5.3",
    "jsdom": "^27.0.1",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.46.4",
    "vite": "^7.2.4",
    "vite-plugin-dts": "^4.5.4",
    "vitest": "^4.0.18"
  }
}